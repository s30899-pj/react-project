{
  "name": "mapforge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "MapForge — edytor map kafelkowych do gier (projekt BIU)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
