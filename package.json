    "axios": "^1.7.7",
    "axios-mock-adapter": "^2.1.0",
    "graphql": "^16.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.3.5",
    "@storybook/react": "^8.3.5",
    "@storybook/react-vite": "^8.3.5",
    "@testing-library/jest-dom": "^6.5.0",
